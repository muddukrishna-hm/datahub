# DataWave SQL Federation — environment variables
# Copy to .env and change values before running in any non-local environment.

# ── Data Sources ──────────────────────────────────────────────────────────────
POSTGRES_PASSWORD=datawave123
MYSQL_ROOT_PASSWORD=datawave123
MYSQL_PASSWORD=datawave123
MINIO_ROOT_PASSWORD=minioadmin123

# ── Apache Ranger ──────────────────────────────────────────────────────────────
RANGER_DB_PASSWORD=RangerPass@1
RANGER_ADMIN_PASSWORD=RangerAdmin@1

# ── Elasticsearch (Audit) ──────────────────────────────────────────────────────
ELASTICSEARCH_PASSWORD=ElasticPass@1

# ── OpenLDAP ───────────────────────────────────────────────────────────────────
# LDAP_ADMIN_PASSWORD must match keycloak/datawave-realm.json bindCredential
LDAP_ADMIN_PASSWORD=adminpassword

# ── Keycloak (SSO) ─────────────────────────────────────────────────────────────
KEYCLOAK_ADMIN_PASSWORD=KeycloakAdmin@1

# ── Deployment ─────────────────────────────────────────────────────────────────
# Set to the public IP or hostname when deploying on EC2 or any remote host.
# Used for Keycloak browser redirects and Superset OIDC callback URLs.
# Leave as localhost for local development.
PUBLIC_HOSTNAME=localhost

# ── Apache Superset ────────────────────────────────────────────────────────────
# SECRET_KEY must be a random string of at least 32 characters in production.
SUPERSET_SECRET_KEY=superset-local-dev-secret-key-change-me
SUPERSET_ADMIN_PASSWORD=SupersetAdmin@1
# SUPERSET_OIDC_SECRET must match keycloak/datawave-realm.json client secret
SUPERSET_OIDC_SECRET=superset-client-secret
