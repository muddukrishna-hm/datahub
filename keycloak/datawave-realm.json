{
  "realm": "datawave",
  "displayName": "DataWave Industries",
  "enabled": true,
  "sslRequired": "none",
  "registrationAllowed": false,
  "loginWithEmailAllowed": true,
  "duplicateEmailsAllowed": false,
  "resetPasswordAllowed": true,
  "editUsernameAllowed": false,
  "bruteForceProtected": false,

  "clients": [
    {
      "clientId": "datawave-app",
      "name": "DataWave Analytics Portal",
      "description": "OAuth2/OIDC client for the DataWave Metabase + OAuth2 Proxy",
      "enabled": true,
      "publicClient": false,
      "secret": "datawave-secret-32chars-long-ok",
      "redirectUris": [
        "http://localhost/oauth2/callback",
        "http://localhost:4180/oauth2/callback",
        "http://localhost:3000/*"
      ],
      "webOrigins": ["http://localhost", "http://localhost:3000"],
      "standardFlowEnabled": true,
      "implicitFlowEnabled": false,
      "directAccessGrantsEnabled": true,
      "serviceAccountsEnabled": false,
      "protocol": "openid-connect",
      "fullScopeAllowed": true,
      "defaultClientScopes": ["openid", "profile", "email", "roles"],
      "optionalClientScopes": ["address", "phone"],
      "protocolMappers": [
        {
          "name": "audience",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-audience-mapper",
          "consentRequired": false,
          "config": {
            "included.client.audience": "datawave-app",
            "id.token.claim": "true",
            "access.token.claim": "true"
          }
        }
      ]
    },
    {
      "clientId": "trino-cli",
      "name": "Trino CLI / API",
      "description": "OAuth2 client for authenticating Trino CLI users",
      "enabled": true,
      "publicClient": true,
      "redirectUris": ["http://localhost:8080/*"],
      "standardFlowEnabled": true,
      "implicitFlowEnabled": false,
      "directAccessGrantsEnabled": true,
      "protocol": "openid-connect",
      "fullScopeAllowed": true
    }
  ],

  "roles": {
    "realm": [
      { "name": "data-analyst",   "description": "Can run SELECT queries on all catalogs" },
      { "name": "data-engineer",  "description": "Can create/alter Iceberg tables" },
      { "name": "data-admin",     "description": "Full access to all catalogs and Ranger admin" }
    ]
  },

  "users": [
    {
      "username": "analyst",
      "email": "analyst@datawave.io",
      "firstName": "Alice",
      "lastName": "Analyst",
      "enabled": true,
      "emailVerified": true,
      "credentials": [{ "type": "password", "value": "analyst123", "temporary": false }],
      "realmRoles": ["data-analyst"]
    },
    {
      "username": "engineer",
      "email": "engineer@datawave.io",
      "firstName": "Bob",
      "lastName": "Engineer",
      "enabled": true,
      "emailVerified": true,
      "credentials": [{ "type": "password", "value": "engineer123", "temporary": false }],
      "realmRoles": ["data-analyst", "data-engineer"]
    },
    {
      "username": "admin",
      "email": "admin@datawave.io",
      "firstName": "Carol",
      "lastName": "Admin",
      "enabled": true,
      "emailVerified": true,
      "credentials": [{ "type": "password", "value": "admin123", "temporary": false }],
      "realmRoles": ["data-analyst", "data-engineer", "data-admin"]
    },
    {
      "username": "krishna",
      "email": "muddukrishnahm@gmail.com",
      "firstName": "Krishna",
      "lastName": "Muddu",
      "enabled": true,
      "emailVerified": true,
      "credentials": [{ "type": "password", "value": "krishna123", "temporary": false }],
      "realmRoles": ["data-analyst", "data-engineer", "data-admin"]
    }
  ],

  "scopeMappings": [
    {
      "client": "datawave-app",
      "roles": ["data-analyst", "data-engineer", "data-admin"]
    }
  ]
}
