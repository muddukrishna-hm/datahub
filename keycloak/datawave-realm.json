{
  "realm": "datawave",
  "enabled": true,
  "sslRequired": "none",
  "registrationAllowed": false,
  "loginWithEmailAllowed": true,
  "clients": [
    {
      "clientId": "superset",
      "name": "Apache Superset",
      "enabled": true,
      "publicClient": false,
      "secret": "superset-client-secret",
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": true,
      "redirectUris": [
        "http://localhost:8088/oauth-authorized/keycloak",
        "http://localhost:8088/*"
      ],
      "webOrigins": ["http://localhost:8088"],
      "protocol": "openid-connect"
    }
  ],
  "components": {
    "org.keycloak.storage.UserStorageProvider": [
      {
        "id": "openldap-provider",
        "name": "openldap",
        "providerId": "ldap",
        "subType": "readonly",
        "subComponents": {
          "org.keycloak.storage.ldap.mappers.LDAPStorageMapper": [
            {
              "id": "username-mapper",
              "name": "username",
              "providerId": "user-attribute-ldap-mapper",
              "subType": "openldap-provider",
              "subComponents": {},
              "config": {
                "ldap.attribute":              ["uid"],
                "user.model.attribute":        ["username"],
                "is.mandatory.in.ldap":        ["true"],
                "read.only":                   ["true"],
                "always.read.value.from.ldap": ["false"]
              }
            },
            {
              "id": "first-name-mapper",
              "name": "first name",
              "providerId": "user-attribute-ldap-mapper",
              "subType": "openldap-provider",
              "subComponents": {},
              "config": {
                "ldap.attribute":              ["cn"],
                "user.model.attribute":        ["firstName"],
                "is.mandatory.in.ldap":        ["true"],
                "read.only":                   ["true"],
                "always.read.value.from.ldap": ["false"]
              }
            },
            {
              "id": "last-name-mapper",
              "name": "last name",
              "providerId": "user-attribute-ldap-mapper",
              "subType": "openldap-provider",
              "subComponents": {},
              "config": {
                "ldap.attribute":              ["sn"],
                "user.model.attribute":        ["lastName"],
                "is.mandatory.in.ldap":        ["true"],
                "read.only":                   ["true"],
                "always.read.value.from.ldap": ["false"]
              }
            },
            {
              "id": "email-mapper",
              "name": "email",
              "providerId": "user-attribute-ldap-mapper",
              "subType": "openldap-provider",
              "subComponents": {},
              "config": {
                "ldap.attribute":              ["mail"],
                "user.model.attribute":        ["email"],
                "is.mandatory.in.ldap":        ["false"],
                "read.only":                   ["true"],
                "always.read.value.from.ldap": ["false"]
              }
            },
            {
              "id": "creation-date-mapper",
              "name": "creation date",
              "providerId": "user-attribute-ldap-mapper",
              "subType": "openldap-provider",
              "subComponents": {},
              "config": {
                "ldap.attribute":              ["createTimestamp"],
                "user.model.attribute":        ["createTimestamp"],
                "is.mandatory.in.ldap":        ["false"],
                "read.only":                   ["true"],
                "always.read.value.from.ldap": ["true"]
              }
            }
          ]
        },
        "config": {
          "enabled":                    ["true"],
          "priority":                   ["0"],
          "editMode":                   ["READ_ONLY"],
          "importEnabled":              ["true"],
          "syncRegistrations":          ["false"],
          "fullSyncPeriod":             ["-1"],
          "changedSyncPeriod":          ["-1"],
          "cachePolicy":                ["DEFAULT"],
          "batchSizeForSync":           ["1000"],
          "vendor":                     ["other"],
          "connectionUrl":              ["ldap://openldap:389"],
          "bindDn":                     ["cn=admin,dc=datawave,dc=io"],
          "bindCredential":             ["adminpassword"],
          "authType":                   ["simple"],
          "usersDn":                    ["ou=users,dc=datawave,dc=io"],
          "usernameLDAPAttribute":      ["uid"],
          "rdnLDAPAttribute":           ["uid"],
          "uuidLDAPAttribute":          ["entryUUID"],
          "userObjectClasses":          ["inetOrgPerson"],
          "searchScope":                ["1"],
          "tls":                        ["false"],
          "pagination":                 ["true"],
          "connectionTimeout":          ["5000"],
          "readTimeout":                ["10000"],
          "referral":                   ["ignore"],
          "trustEmail":                 ["true"],
          "allowKerberosAuthentication":["false"]
        }
      }
    ]
  }
}
