{
  "name": "trino",
  "displayName": "Trino",
  "implClass": "org.apache.ranger.services.trino.RangerServiceTrino",
  "label": "Trino Server",
  "description": "Trino SQL Federation Engine",
  "resources": [
    {
      "name": "catalog",
      "type": "string",
      "level": 10,
      "mandatory": true,
      "lookupSupported": true,
      "label": "Trino Catalog",
      "description": "Trino Catalog (e.g. postgresql, mysql, iceberg)"
    },
    {
      "name": "schema",
      "type": "string",
      "level": 20,
      "mandatory": false,
      "lookupSupported": true,
      "parent": "catalog",
      "label": "Trino Schema"
    },
    {
      "name": "table",
      "type": "string",
      "level": 30,
      "mandatory": false,
      "lookupSupported": true,
      "parent": "schema",
      "label": "Trino Table"
    },
    {
      "name": "column",
      "type": "string",
      "level": 40,
      "mandatory": false,
      "lookupSupported": true,
      "parent": "table",
      "label": "Trino Column"
    }
  ],
  "accessTypes": [
    { "name": "select",       "label": "SELECT" },
    { "name": "insert",       "label": "INSERT" },
    { "name": "delete",       "label": "DELETE" },
    { "name": "update",       "label": "UPDATE" },
    { "name": "create",       "label": "CREATE" },
    { "name": "drop",         "label": "DROP" },
    { "name": "alter",        "label": "ALTER" },
    { "name": "use",          "label": "USE"    },
    { "name": "show",         "label": "SHOW"   },
    { "name": "execute",      "label": "EXECUTE"},
    { "name": "impersonate",  "label": "IMPERSONATE" },
    { "name": "grant",        "label": "GRANT" }
  ],
  "dataMaskDef": {
    "maskTypes": [
      { "name": "MASK",           "label": "Redact",               "description": "Replace all characters with x" },
      { "name": "MASK_NULL",      "label": "Nullify",              "description": "Replace with NULL" },
      { "name": "MASK_SHOW_LAST_4", "label": "Show last 4 chars", "description": "Show only last 4 characters" },
      { "name": "CUSTOM",         "label": "Custom expression",    "description": "Custom SQL mask expression" }
    ],
    "resources": [
      { "name": "catalog", "mandatory": true },
      { "name": "schema",  "mandatory": true },
      { "name": "table",   "mandatory": true },
      { "name": "column",  "mandatory": true }
    ]
  },
  "configs": [
    {
      "itemId": 1,
      "name": "username",
      "type": "String",
      "subType": "",
      "mandatory": true,
      "validationRegEx": "",
      "validationMessage": "",
      "uiHint": "",
      "label": "Username"
    },
    {
      "itemId": 2,
      "name": "password",
      "type": "Password",
      "subType": "",
      "mandatory": true,
      "validationRegEx": "",
      "validationMessage": "",
      "uiHint": "",
      "label": "Password"
    },
    {
      "itemId": 3,
      "name": "jdbc.url",
      "type": "String",
      "subType": "",
      "mandatory": true,
      "validationRegEx": "",
      "validationMessage": "",
      "uiHint": "",
      "label": "JDBC URL",
      "defaultValue": "jdbc:trino://trino:8080"
    }
  ]
}
